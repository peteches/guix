(define-public node-libpq-1.11.0
  (package
    (name "node-libpq")
    (version "1.11.0")
    (source
     (origin
       (method url-fetch)
       (uri "https://registry.npmjs.org/libpq/-/libpq-1.11.0.tgz")
       (sha256
        (base32 "10923axxrz99if6mm3zi3g3xsdvb2xa3qbq2dvqcwx214nm424gn"))))
    (build-system node-build-system)
    (arguments
     (list
      #:tests? #f
      #:phases
      #~(modify-phases %standard-phases
          (delete 'build)

          (add-after 'unpack 'patch-pg-config-lookup
            (lambda _
              ;; Upstream tries to discover pg_config using `which` and by
              ;; searching /usr and /opt.  Guix has neither by design, so point
              ;; binding.gyp directly at PostgreSQL's pg_config.
              (substitute* "binding.gyp"
                (("which pg_config \\|\\| find /usr/bin /usr/local/bin /usr/pg\\* /opt -executable -name pg_config -print -quit")
                 (string-append "echo "
                                #$(file-append postgresql "/bin/pg_config"))))))

          (add-before 'install 'set-node-gyp-python
            (lambda _
              ;; node-gyp needs Python to configure native addons.
              (setenv "PYTHON" #$(file-append python "/bin/python3"))
              (setenv "npm_config_python"
                      #$(file-append python "/bin/python3"))))

          (add-before 'repack 'disable-lifecycle-scripts
            (lambda _
              (modify-json
               (delete-fields '("scripts.prepare" "scripts.postinstall")
                              #:strict? #f))))

          (add-after 'patch-dependencies 'delete-dev-dependencies
            (lambda _
              (modify-json
               (delete-dependencies
                '("async" "buffer-from" "lodash" "mocha" "okay"))))))))

    (native-inputs
     (list python
           pkg-config))

    ;; postgresql provides libpq, libpq-fe.h, and pg_config.
    (inputs
     (list postgresql
           node-nan-2.26.2
           node-bindings-1.5.0))

    (home-page "https://github.com/brianc/node-libpq#readme")
    (synopsis "Low-level native bindings to PostgreSQL libpq")
    (description "Low-level native bindings to PostgreSQL libpq.")
