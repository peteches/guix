(define-public node-bcrypt-6.0.0
  (package
    (name "node-bcrypt")
    (version "6.0.0")
    (source
     (origin
       (method url-fetch)
       (uri "https://registry.npmjs.org/bcrypt/-/bcrypt-6.0.0.tgz")
       (sha256
        (base32 "085fnmjzq3b0ps02pvhrdiacq52yyml0pk869rs6q1kgl36ph91v"))))
    (build-system node-build-system)
    (arguments
     (list
      #:tests? #f
      #:phases
      #~(modify-phases %standard-phases
          (add-after 'patch-dependencies 'delete-dev-dependencies
            (lambda _
              (modify-json (delete-dependencies '("jest" "prebuildify")))))
          ;; Disable the npm install script so it doesn't try to run
          ;; node-gyp-build (which would attempt to load the prebuilt
          ;; binary that has no RPATH in the Guix store).
          (add-after 'delete-dev-dependencies 'disable-install-script
            (lambda _
              (modify-json
               (replace-fields
                '(("scripts.install"
                   . "echo 'native addon built in build phase'"))))))
          ;; Build the C++ native addon directly using npm's bundled
          ;; node-gyp.  Guix's ld-wrapper adds the correct store RPATH.
          (replace 'build
            (lambda* (#:key inputs #:allow-other-keys)
              (let ((node-gyp
                     (string-append
                      (assoc-ref inputs "node")
                      "/lib/node_modules/npm/node_modules/node-gyp/bin/node-gyp.js"))
                    (nodedir (assoc-ref inputs "node")))
                (setenv "npm_config_nodedir" nodedir)
                (invoke node-gyp "rebuild"))))
          ;; Remove prebuilt binaries for all platforms before repacking.
          ;; They have no RPATH and fail validate-runpath; the compiled
          ;; build/Release/bcrypt_lib.node (with store RPATH from ld-wrapper)
          ;; is used instead by node-gyp-build at runtime.
          (add-before 'repack 'delete-prebuilds
            (lambda _
              (when (file-exists? "prebuilds")
                (delete-file-recursively "prebuilds")))))))
    (native-inputs (list python))
    (inputs (list node-node-gyp-build-4.8.4 node-node-addon-api-8.8.0))
    (home-page "https://github.com/kelektiv/node.bcrypt.js#readme")
