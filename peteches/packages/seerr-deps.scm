(define-public node-sqlite3-5.1.7
  (package
    (name "node-sqlite3")
    (version "5.1.7")
    (source
     (origin
       (method url-fetch)
       (uri "https://registry.npmjs.org/sqlite3/-/sqlite3-5.1.7.tgz")
       (sha256
        (base32 "06xbxknb1hwbcw682qhw5w5is7728pbnhsgp6svaf197w3g9pk24"))))
    (build-system node-build-system)
    (arguments
     (list
      #:tests? #f
      #:phases
      #~(modify-phases %standard-phases
          (delete 'build)
          (add-before 'repack 'disable-lifecycle-scripts
            (lambda _
              (modify-json
               (delete-fields '("scripts.prepare" "scripts.postinstall")
                              #:strict? #f))))
	  (add-after 'configure 'patch-minipass-imports
		     (lambda _
		       ;; Guix's node-build-system can pair older packages expecting
		       ;; require("minipass") to return the class directly with a newer
		       ;; minipass where the class is exported as { Minipass }.
		       ;;
		       ;; Different packages spell the local binding differently:
		       ;;   minizlib    -> Minipass
		       ;;   fs-minipass -> MiniPass
		       (for-each
			(lambda (file)
			  (when (file-exists? file)
			    (substitute* file
					 ;; minizlib style.
					 (("const Minipass = require\\('minipass'\\)")
					  "const { Minipass } = require('minipass')")
					 (("const Minipass = require\\(\"minipass\"\\)")
					  "const { Minipass } = require(\"minipass\")")

					 ;; fs-minipass style.
					 (("const MiniPass = require\\('minipass'\\)")
					  "const { Minipass: MiniPass } = require('minipass')")
					 (("const MiniPass = require\\(\"minipass\"\\)")
					  "const { Minipass: MiniPass } = require(\"minipass\")"))))
			'("node_modules/minizlib/index.js"
			  "node_modules/fs-minipass/index.js"))))
          (add-after 'patch-dependencies 'delete-dev-dependencies
		     (lambda _
		       (modify-json (delete-dependencies '("mocha" "eslint" "prebuild"
							   "node-gyp")))))
	  (add-before 'install 'set-compiler-for-node-gyp
		      (lambda _
			;; node-gyp's generated makefiles may invoke "cc"/"c++".
			;; In Guix, be explicit so the build does not rely on generic names.
			(setenv "CC" "gcc")
			(setenv "CXX" "g++"))))))
    (inputs
     (list python
	   node-prebuild-install-7.1.3
	   node-node-addon-api-7.1.1
	   node-bindings-1.5.0
	   node-tar-6.2.1))
    (home-page "https://github.com/TryGhost/node-sqlite3")
    (synopsis "Asynchronous, non-blocking SQLite3 bindings")
    (description "Asynchronous, non-blocking SQLite3 bindings")
    (license license:bsd-3)))

