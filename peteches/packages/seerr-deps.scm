(define-public node-isaacs-cliui-8.0.2
  (package
    (name "node-isaacs-cliui")
    (version "8.0.2")
    (source
     (origin
       (method url-fetch)
       (uri "https://registry.npmjs.org/@isaacs/cliui/-/cliui-8.0.2.tgz")
       (sha256
        (base32 "1hp481vmgcbn91byd6iyrf2qm0a2wyb9qg127jkhknq9zil3rbim"))))
    (build-system node-build-system)
    (arguments
     (list
      #:tests? #f
      #:phases
      #~(modify-phases %standard-phases
          ;; The package ships usable JS already.
          (delete 'build)

          ;; This must run before `configure', because `configure' runs:
          ;;
          ;;   npm --offline --ignore-scripts --install-links install
          ;;
          ;; If devDependencies remain, npm tries to fetch @types/node,
          ;; c8, mocha, gts, etc.
          (add-before 'configure 'delete-dev-dependencies
            (lambda _
              (modify-json
               (delete-fields '("devDependencies"
                                "scripts.prepare"
                                "scripts.postinstall")
                              #:strict? #f))))

          ;; Rewrite npm registry dependencies to local file dependencies.
          ;;
          ;; This version intentionally keeps the Scheme simple: no `match',
          ;; no old-style named input pairs.
          (add-after 'delete-dev-dependencies 'patch-runtime-dependencies
            (lambda* (#:key inputs #:allow-other-keys)
              (let* ((string-width
                      (search-input-directory
                       inputs "lib/node_modules/string-width"))
                     (strip-ansi
                      (search-input-directory
                       inputs "lib/node_modules/strip-ansi"))
                     (wrap-ansi
                      (search-input-directory
                       inputs "lib/node_modules/wrap-ansi")))

                (format #t "Patching @isaacs/cliui runtime dependencies...~%")
                (format #t "  string-width: ~a~%" string-width)
                (format #t "  strip-ansi:   ~a~%" strip-ansi)
                (format #t "  wrap-ansi:    ~a~%" wrap-ansi)

                (modify-json
                 (lambda (json)
                   (assoc-set!
                    json "dependencies"
                    `(("string-width" . ,(string-append
                                           "file:" string-width))
                      ("strip-ansi" . ,(string-append
                                         "file:" strip-ansi))
                      ("wrap-ansi" . ,(string-append
                                        "file:" wrap-ansi))

                      ;; Upstream uses npm aliases for CommonJS
                      ;; compatibility:
                      ;;
                      ;;   string-width-cjs -> string-width@4
                      ;;   strip-ansi-cjs   -> strip-ansi@6
                      ;;   wrap-ansi-cjs    -> wrap-ansi@7
                      ;;
                      ;; For this first pass, point them at the available
                      ;; local modules so npm does not try the registry.
                      ;; If runtime/tests complain later, split these into
                      ;; explicit -cjs alias packages.
                      ("string-width-cjs" . ,(string-append
                                               "file:" string-width))
                      ("strip-ansi-cjs" . ,(string-append
                                             "file:" strip-ansi))
                      ("wrap-ansi-cjs" . ,(string-append
                                            "file:" wrap-ansi))))
                   json))))))))
    (inputs
     (list node-wrap-ansi-8.1.0
           node-strip-ansi-7.1.0
           node-string-width-5.1.2))
