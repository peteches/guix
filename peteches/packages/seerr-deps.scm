          ;; The npm tarball is already the published package.
          (delete 'build)

          ;; Do all metadata surgery before `configure', because `configure'
          ;; runs `npm install --offline`.
          (add-after 'unpack 'relax-package-json
            (lambda _
              ;; @ladjs/consolidate advertises lots of template engines as
              ;; peer/optional/dev dependencies.  npm 7+ tries to resolve peer
              ;; dependencies automatically, which causes ENOTCACHED for things
              ;; like @babel/core in Guix's offline npm build.
              ;;
              ;; Runtime consumers should provide whichever template engines
              ;; they actually use; this package should not pull every possible
              ;; engine into its closure.
              (for-each
               (lambda (file)
                 (with-directory-excursion (dirname file)
                   (modify-json
                    (delete-fields '("scripts"
                                     "devDependencies"
                                     "devEngines"
                                     "peerDependencies"
                                     "peerDependenciesMeta"
                                     "optionalDependencies")
                                   #:strict? #f))))
