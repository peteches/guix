(define-public node-cosmiconfig-7.1.0
  (package
    (name "node-cosmiconfig")
    (version "7.1.0")
    (source
     (origin
       (method url-fetch)
       (uri "https://registry.npmjs.org/cosmiconfig/-/cosmiconfig-7.1.0.tgz")
       (sha256
        (base32 "1mfnjsnkk7y2fxbh8jx42plszrn5xg5vyiq56axigsli25hpsirb"))))
    (build-system node-build-system)
    (arguments
     (list
      #:tests? #f
      #:phases
      #~(modify-phases %standard-phases
          ;; The npm tarball already contains distributable JS.
          (delete 'build)

          ;; Must run before `configure', because `configure' invokes:
          ;;
          ;;   npm --offline --ignore-scripts --install-links install
          ;;
          ;; Remove upstream development metadata so npm does not try to
          ;; resolve Babel/Jest/TypeScript tooling from the offline cache.
          (add-after 'unpack 'strip-development-metadata
            (lambda _
              (invoke "node" "-e"
                      "
const fs = require('fs');
const file = 'package.json';
const pkg = JSON.parse(fs.readFileSync(file, 'utf8'));

delete pkg.devDependencies;
delete pkg.peerDependenciesMeta;
delete pkg.scripts;

/*
 * cosmiconfig 7.1.0 lists @types/parse-json as a normal dependency.
 * It is TypeScript-only metadata and is not needed at runtime.
 */
if (pkg.dependencies) {
  delete pkg.dependencies['@types/parse-json'];
}

fs.writeFileSync(file, JSON.stringify(pkg, null, 2) + '\\n');
"))))))
    (inputs
     (list node-import-fresh-3.3.1
           node-parse-json-5.2.0
           node-path-type-4.0.0
           node-yaml))
