# ~/.config/matugen/templates/hyprlock-colors.conf
# Generated to ~/.config/hypr/colors-hyprlock.conf

$bg = rgba({{ colors.background.default.hex_stripped }}ff)
$bg_panel = rgba({{ colors.surface_container.default.hex_stripped }}aa)
$surface = rgba({{ colors.surface.default.hex_stripped }}cc)

$fg = rgba({{ colors.on_surface.default.hex_stripped }}ff)
$fg_dim = rgba({{ colors.on_surface_variant.default.hex_stripped }}ff)
$muted = rgba({{ colors.outline.default.hex_stripped }}ff)

$primary = rgba({{ colors.primary.default.hex_stripped }}ff)
$secondary = rgba({{ colors.secondary.default.hex_stripped }}ff)
$tertiary = rgba({{ colors.tertiary.default.hex_stripped }}ff)

$error = rgba({{ colors.error.default.hex_stripped }}ff)
$error_container = rgba({{ colors.error_container.default.hex_stripped }}ff)

$shadow = rgba({{ colors.shadow.default.hex_stripped }}88)
$shadow_strong = rgba({{ colors.shadow.default.hex_stripped }}99)