# ~/.config/hypr/hyprlock.conf
# Fancy frosted-glass hyprlock config using matugen colours

source = ~/.cache/matugen/hyprlock-colours.config

general {
    hide_cursor = true
    ignore_empty_input = true
    immediate_render = true
    fail_timeout = 2200
    text_trim = true
}

animations {
    enabled = true
}

bezier = lockEase, 0.05, 0.9, 0.1, 1.05
animation = fadeIn, 1, 3, lockEase
animation = fadeOut, 1, 2, lockEase
animation = inputFieldDots, 1, 2, lockEase
animation = inputFieldColors, 1, 3, lockEase
animation = inputFieldFade, 1, 2, lockEase

background {
    monitor =
    path = screenshot
    color = $bg

    blur_passes = 3
    blur_size = 8
    noise = 0.0117
    contrast = 0.90
    brightness = 0.58
    vibrancy = 0.25
    vibrancy_darkness = 0.15

    zindex = -10
}

shape {
    monitor =
    size = 520, 450
    position = 0, 0
    halign = center
    valign = center

    color = $bg_panel
    rounding = 32
    border_size = 2
    border_color = $primary $tertiary 45deg

    shadow_passes = 3
    shadow_size = 10
    shadow_color = $shadow
    shadow_boost = 1.5

    zindex = 0
}

label {
    monitor =
    text = $TIME
    position = 0, -135
    halign = center
    valign = center

    color = $fg
    font_size = 82
    font_family = JetBrainsMono Nerd Font
    text_align = center

    shadow_passes = 2
    shadow_size = 4
    shadow_color = $shadow_strong

    zindex = 2
}

label {
    monitor =
    text = cmd[update:60000] date +"%A, %d %B"
    position = 0, -70
    halign = center
    valign = center

    color = $fg_dim
    font_size = 18
    font_family = JetBrainsMono Nerd Font
    text_align = center

    zindex = 2
}

label {
    monitor =
    text = Welcome back, $USER
    position = 0, 7
    halign = center
    valign = center

    color = $primary
    font_size = 20
    font_family = JetBrainsMono Nerd Font
    text_align = center

    zindex = 2
}

input-field {
    monitor =
    size = 340, 58
    position = 0, 78
    halign = center
    valign = center

    outline_thickness = 2
    rounding = 18

    outer_color = $primary $tertiary 45deg
    inner_color = $surface
    font_color = $fg

    check_color = $secondary $primary 120deg
    fail_color = $error $error_container 45deg
    capslock_color = $tertiary

    dots_size = 0.25
    dots_spacing = 0.25
    dots_center = true
    dots_rounding = -1

    fade_on_empty = false
    placeholder_text = <i>Enter password</i>
    fail_text = <i>$FAIL <b>($ATTEMPTS)</b></i>

    shadow_passes = 2
    shadow_size = 6
    shadow_color = $shadow

    zindex = 3
}

label {
    monitor =
    text = Press Esc to clear input
    position = 0, 0
    halign = center
    valign = bottom

    color = $muted
    font_size = 12
    font_family = JetBrainsMono Nerd Font

    zindex = 2
}