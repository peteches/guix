#!/usr/bin/env bash
set -euo pipefail

program=${0##*/}
script_version=2026-06-25-dms-direct-settings-run-restart
state_dir=${XDG_STATE_HOME:-$HOME/.local/state}/peteches
cache_dir=${XDG_CACHE_HOME:-$HOME/.cache}
config_dir=${XDG_CONFIG_HOME:-$HOME/.config}
log_file=$state_dir/matugen-apply.log

dms_theme_dir=$cache_dir/matugen/dms
dms_theme_file=$dms_theme_dir/dynamic-theme.json
dms_template_file=$state_dir/dms-theme-template.json
dms_config_file=$state_dir/matugen-dms-theme.toml

usage() {
  cat <<USAGE
Usage: $program IMAGE

Generate matugen colours from IMAGE using ~/.config/matugen/config.toml.
This is intended to run after the wallpaper has changed, independent of DMS'
internal theme worker.

Environment:
  PETECHES_MATUGEN_MODE             Matugen mode, default: dark
  PETECHES_MATUGEN_TYPE             Matugen scheme type, default: scheme-tonal-spot
  PETECHES_MATUGEN_SOURCE_COLOR_INDEX
                                      Source-colour candidate index, default: 0.
                                      Set empty to let matugen prompt interactively.
  PETECHES_MATUGEN_RELOAD_HYPRLAND  Reload Hyprland after generation, default: 1
  PETECHES_MATUGEN_RELOAD_EMACS     Reload Emacs daemon theme, default: 1
  PETECHES_MATUGEN_UPDATE_DMS       Update DMS custom theme file, default: 1
  PETECHES_MATUGEN_DMS_RESTART      Restart DMS after switching theme, default: 0
  DMS_QUICKSHELL_CONFIG_DIR         DMS quickshell config dir, default: ~/.guix-home/profile/share/quickshell
  MATUGEN_BIN                       Override matugen executable
  DMS_BIN                           Override DMS executable
USAGE
}

log() {
  mkdir -p "$state_dir"
  printf '[%(%Y-%m-%dT%H:%M:%S%z)T] %s\n' -1 "$*" >> "$log_file"
}

die() {
  printf '%s: %s\n' "$program" "$*" >&2
  log "ERROR: $*"
  exit 1
}

resolve_matugen_bin() {
  if [[ -n ${MATUGEN_BIN:-} ]]; then
    printf '%s\n' "$MATUGEN_BIN"
    return 0
  fi

  if [[ -x $HOME/.guix-home/profile/bin/matugen ]]; then
    printf '%s\n' "$HOME/.guix-home/profile/bin/matugen"
    return 0
  fi

  command -v matugen 2>/dev/null || return 1
}

resolve_dms_bin() {
  if [[ -n ${DMS_BIN:-} ]]; then
    printf '%s\n' "$DMS_BIN"
    return 0
  fi

  if [[ -x $HOME/.guix-home/profile/bin/dms ]]; then
    printf '%s\n' "$HOME/.guix-home/profile/bin/dms"
    return 0
  fi

  command -v dms 2>/dev/null || return 1
}

reload_hyprland() {
  [[ ${PETECHES_MATUGEN_RELOAD_HYPRLAND:-1} != 0 ]] || return 0
  [[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]] || return 0

  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl reload >> "$log_file" 2>&1 || log "WARN: hyprctl reload failed"
  fi
}

reload_emacs() {
  [[ ${PETECHES_MATUGEN_RELOAD_EMACS:-1} != 0 ]] || return 0

  if command -v emacsclient >/dev/null 2>&1; then
    emacsclient --eval "(when (fboundp 'peteches/load-matugen-theme) (peteches/load-matugen-theme t))" >> "$log_file" 2>&1 \
      || log "WARN: emacsclient theme reload failed"
  fi
}

write_dms_theme_template() {
  mkdir -p "$state_dir" "$dms_theme_dir"
  cat > "$dms_template_file" <<'TEMPLATE'
{
  "name": "Peteches Matugen Dynamic",
  "primary": "{{colors.primary.default.hex}}",
  "primaryText": "{{colors.on_primary.default.hex}}",
  "primaryContainer": "{{colors.primary_container.default.hex}}",
  "secondary": "{{colors.secondary.default.hex}}",
  "surface": "{{colors.surface.default.hex}}",
  "surfaceText": "{{colors.on_surface.default.hex}}",
  "surfaceVariant": "{{colors.surface_variant.default.hex}}",
  "surfaceVariantText": "{{colors.on_surface_variant.default.hex}}",
  "surfaceTint": "{{colors.primary.default.hex}}",
  "background": "{{colors.background.default.hex}}",
  "backgroundText": "{{colors.on_background.default.hex}}",
  "outline": "{{colors.outline.default.hex}}",
  "surfaceContainer": "{{colors.surface_container.default.hex}}",
  "surfaceContainerHigh": "{{colors.surface_container_high.default.hex}}",
  "surfaceContainerHighest": "{{colors.surface_container_highest.default.hex}}",
  "error": "{{colors.error.default.hex}}",
  "warning": "{{colors.tertiary.default.hex}}",
  "info": "{{colors.secondary.default.hex}}",
  "matugen_type": "scheme-tonal-spot"
}
TEMPLATE

  cat > "$dms_config_file" <<EOF2
[config]

[templates.peteches_dms_custom_theme]
input_path = '$dms_template_file'
output_path = '$dms_theme_file'
EOF2
}

json_string() {
  local value=$1
  value=${value//\\/\\\\}
  value=${value//"/\\"}
  value=${value//$'\n'/\\n}
  printf '"%s"' "$value"
}

update_dms_settings_file() {
  local settings_file=$config_dir/DankMaterialShell/settings.json
  local tmp_file

  mkdir -p "$(dirname "$settings_file")"
  if [[ ! -s $settings_file ]]; then
    printf '{}\n' > "$settings_file"
  fi

  if command -v jq >/dev/null 2>&1; then
    tmp_file=$(mktemp "${settings_file}.XXXXXX")
    jq --arg theme custom --arg file "$dms_theme_file" \
      '.currentThemeName = $theme | .customThemeFile = $file' \
      "$settings_file" > "$tmp_file" \
      && mv "$tmp_file" "$settings_file" \
      || {
        rm -f "${tmp_file:-}"
        log "WARN: could not update DMS settings.json with jq"
        return 1
      }
    log "updated DMS settings file: $settings_file"
    return 0
  fi

  log "WARN: jq not found; cannot update $settings_file directly"
  return 1
}

restart_dms_shell() {
  local dms_bin quickshell_dir restart_log

  dms_bin=$(resolve_dms_bin) || {
    log "WARN: dms not found; cannot restart DMS"
    return 1
  }

  quickshell_dir=${DMS_QUICKSHELL_CONFIG_DIR:-$HOME/.guix-home/profile/share/quickshell}
  restart_log=$state_dir/dms-restart.log

  if [[ ! -d $quickshell_dir ]]; then
    log "WARN: DMS quickshell config directory not found: $quickshell_dir"
    return 1
  fi

  log "restarting DMS via kill/run with config: $quickshell_dir"
  "$dms_bin" kill >> "$log_file" 2>&1 || log "WARN: dms kill failed or no DMS process was running"

  # Do not use `dms restart` here: on this DMS build it can terminate the
  # running shell without starting a replacement.  Start it the same way the
  # Hyprland autostart does.
  nohup "$dms_bin" run -c "$quickshell_dir" >> "$restart_log" 2>&1 &
  log "DMS restart launched; output: $restart_log"
}

set_dms_custom_theme() {
  [[ -s $dms_theme_file ]] || {
    log "WARN: DMS custom theme file missing or empty: $dms_theme_file"
    return 0
  }

  # DMS 1.4 does not expose a working settings.set IPC target on all builds.
  # Persist the custom theme through settings.json and only use IPC for the
  # theme-mode refresh hint.  DMS must be restarted once if it was already
  # running in dynamic mode, because the settings file is read at startup.
  update_dms_settings_file || true

  if dms_bin=$(resolve_dms_bin); then
    "$dms_bin" ipc call theme "$mode" >> "$log_file" 2>&1 \
      || log "WARN: could not refresh DMS theme mode"

    if [[ ${PETECHES_MATUGEN_DMS_RESTART:-0} != 0 ]]; then
      restart_dms_shell || log "WARN: DMS kill/run restart failed"
    else
      log "DMS settings were updated; restart DMS once if it is still showing the dynamic theme"
    fi
  else
    log "WARN: dms not found; updated settings.json but could not notify running DMS"
  fi
}

generate_dms_theme() {
  [[ ${PETECHES_MATUGEN_UPDATE_DMS:-1} != 0 ]] || return 0

  write_dms_theme_template

  local dms_args=(image "$image" -c "$dms_config_file" -m "$mode" -t "$type")
  if [[ -n $source_color_index ]]; then
    dms_args+=(--source-color-index "$source_color_index")
  fi

  log "generating DMS custom theme: $dms_theme_file"
  "$matugen_bin" "${dms_args[@]}" >> "$log_file" 2>&1 || {
    log "WARN: DMS custom theme generation failed"
    return 0
  }

  set_dms_custom_theme
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  usage
  exit 0
fi

[[ $# -eq 1 ]] || die "expected exactly one image path"
image=$1

case $image in
  '~') image=$HOME ;;
  '~/'*) image=$HOME/${image#~/} ;;
esac

[[ -f $image ]] || die "not a file: $image"
image=$(cd "$(dirname "$image")" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$image")")

config_file=$config_dir/matugen/config.toml
[[ -r $config_file ]] || die "matugen config not readable: $config_file"

matugen_bin=$(resolve_matugen_bin) || die "matugen not found; expected $HOME/.guix-home/profile/bin/matugen or a matugen in PATH"
mode=${PETECHES_MATUGEN_MODE:-dark}
type=${PETECHES_MATUGEN_TYPE:-scheme-tonal-spot}
source_color_index=${PETECHES_MATUGEN_SOURCE_COLOR_INDEX-0}

matugen_args=(image "$image" -m "$mode" -t "$type")
if [[ -n $source_color_index ]]; then
  matugen_args+=(--source-color-index "$source_color_index")
fi

log "$program version: $script_version"
log "generating colours from: $image"
log "command: $matugen_bin image <image> -m $mode -t $type${source_color_index:+ --source-color-index $source_color_index}"

"$matugen_bin" "${matugen_args[@]}" >> "$log_file" 2>&1 || die "matugen generation failed; see $log_file"

generate_dms_theme
reload_emacs
reload_hyprland
emacsclient --eval "(when (fboundp 'peteches/load-matugen-theme) (peteches/load-matugen-theme t))"
log "completed: $image"
